{
  "meta": {
    "schemaVersion": "xiaozhua.kb_tpl.safety_notices.v1",
    "bundleVersion": "1.0.0",
    "description": "免责声明片段库。是否必填由 TriageCoreResult.safetyNoticeRequired（② SafetyByFlag）决定。"
  },
  "snippets": {
    "SNIP-NONE": "",
    "SNIP-GENERAL": "以上建议仅供参考，不能替代兽医面诊与专业诊断。",
    "SNIP-EMERGENCY": "以上为紧急分诊提示，请尽快寻求专业兽医帮助；本服务不提供确诊或治疗保证。",
    "SNIP-DATA": "当前结论受监测数据完整性限制，请在数据恢复后重新评估。"
  },
  "resolveRules": [
    {
      "when": { "safetyNoticeRequired": false },
      "snippetId": "SNIP-NONE"
    },
    {
      "when": {
        "safetyNoticeRequired": true,
        "finalRiskLevel": "emergency"
      },
      "snippetId": "SNIP-EMERGENCY"
    },
    {
      "when": {
        "safetyNoticeRequired": true,
        "primaryFlagIn": ["DATA_MISSING", "DATA_STALE"]
      },
      "snippetId": "SNIP-DATA"
    },
    {
      "when": { "safetyNoticeRequired": true },
      "snippetId": "SNIP-GENERAL"
    }
  ]
}
