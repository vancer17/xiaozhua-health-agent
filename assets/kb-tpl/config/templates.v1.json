{
  "meta": {
    "schemaVersion": "xiaozhua.kb_tpl.templates.v1",
    "bundleVersion": "1.0.0",
    "description": "20 条 risk×primaryFlag 文案模板（copy + guidance + binding）。合规约束由 triage-core policyTables 注入。"
  },
  "templates": {
    "normal.NORMAL_DAILY": {
      "meta": {
        "templateId": "normal.NORMAL_DAILY",
        "riskLevel": "normal",
        "primaryFlag": "NORMAL_DAILY",
        "bundleVersion": "1.0.0",
        "name": "正常健康状态",
        "caseIds": ["normal_dog_daily_check"],
        "toneProfileId": "TONE-NORMAL",
        "evidenceStyle": "bullets_light_polish"
      },
      "copy": {
        "titlePattern": "{petName}当前健康状态平稳",
        "summaryOutline": [
          "当前体征与日常状态未见明显异常",
          "主人描述与监测数据一致",
          "建议保持日常观察"
        ],
        "recommendationTemplate": "可继续当前作息与饮水习惯，保持适度活动。",
        "whenToSeeVetTemplate": "若出现精神萎靡、食欲骤降、呕吐、呼吸困难等变化，建议联系兽医。"
      },
      "guidance": {
        "llmInstructions": "语气轻松但不保证；不要写「绝对健康」或过度保证性结论。"
      },
      "binding": {
        "slots": ["petName", "temperature", "heartRate", "userReportText"]
      }
    },
    "watch.POST_EXERCISE": {
      "meta": {
        "templateId": "watch.POST_EXERCISE",
        "riskLevel": "watch",
        "primaryFlag": "POST_EXERCISE",
        "bundleVersion": "1.0.0",
        "name": "运动后指标偏高",
        "caseIds": ["mild_fever_after_exercise", "heart_rate_high_after_play"],
        "toneProfileId": "TONE-WATCH",
        "evidenceStyle": "bullets_light_polish",
        "notes": "CTX-09a/09b 共用；#2 突出体温，#5 突出心率，勿暗示心脏病诊断"
      },
      "copy": {
        "titlePattern": "活动后指标偏高，建议休息后复查",
        "summaryOutline": [
          "{exerciseContext}后{primaryVital}偏高较常见",
          "当前整体状态需结合运动情境理解",
          "休息补水后请复查监测数据"
        ],
        "recommendationTemplate": "请先让{petName}在阴凉处休息并补充饮水，安静30～60分钟后再查看指标。",
        "whenToSeeVetTemplate": "若休息后体温或心率仍偏高，或出现呕吐、精神萎靡、呼吸困难，建议联系兽医。"
      },
      "guidance": {
        "llmInstructions": "必须点明「运动后」或「活动后」情境；心率偏高时不要暗示心脏病诊断；禁止 emergency 语气。"
      },
      "binding": {
        "slots": ["petName", "exerciseContext", "exerciseNote", "temperature", "heartRate", "activityLevel"],
        "summarySlotPriority": {
          "primaryVital": ["temperature", "heartRate"]
        }
      }
    },
