# =============================================================================
# 小爪健康分诊 Agent — 运行时配置（非业务规则）
# =============================================================================

# --- HTTP API（前缀 HEALTH_API_）---
HEALTH_API_HOST=0.0.0.0
HEALTH_API_PORT=8080
HEALTH_API_PRELOAD_COPY_BUNDLE=true
HEALTH_API_ACCESS_LOG=true
# HEALTH_API_API_TITLE=小爪 AI 健康/兽医分诊 Agent V1
# HEALTH_API_API_VERSION=0.1.0
HEALTH_API_INTERNAL_PREFIX=/internal
HEALTH_API_INTELLIGENT_ENABLED=true

# --- LLM：通义千问（前缀 QWEN_；copy-llm / LLM 管道）---
# QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_TIMEOUT_SEC=30
QWEN_MAX_RETRIES=2
QWEN_DEFAULT_TEMPERATURE=0.4
QWEN_DEFAULT_MAX_TOKENS=1200

# --- 制品路径（前缀 XIAOZHUA_；相对路径基于项目根）---
# XIAOZHUA_PROJECT_ROOT=
XIAOZHUA_CASES_PATH=docs/cases/health_triage_cases.v1.json
# 兼容旧名 KB_TPL_DIR：
KB_TPL_DIR=assets/kb-tpl/config
XIAOZHUA_KB_FORBID_PATH=assets/kb-forbid/forbidden_patterns.v1.json
XIAOZHUA_KB_SYN_PATH=assets/kb-syn/kb-syn.v1.json
XIAOZHUA_KB_ACTION_PATH=assets/kb-action/actions.v1.json
# 兼容旧名 TRIAGE_CORE_PATH（预留；当前规则仍内嵌于 Python）：
TRIAGE_CORE_PATH=assets/triage-core/triage-core.v1.json
XIAOZHUA_ACTION_MATRIX_PATH=assets/eval/action_matrix.v1.json

# --- 管道调试与行为开关（前缀 XIAOZHUA_PIPELINE_）---
XIAOZHUA_PIPELINE_SKIP_CONTENT_GUARD=false
XIAOZHUA_PIPELINE_SKIP_FINAL_SCHEMA_CHECK=false
XIAOZHUA_PIPELINE_SKIP_MERGE_READY_CHECK=false
XIAOZHUA_PIPELINE_GUARD_MODE=strict
XIAOZHUA_PIPELINE_LLM_ENABLED=false
XIAOZHUA_PIPELINE_ENABLE_MERGE_FALLBACK=true
XIAOZHUA_PIPELINE_ENABLE_FINAL_SCHEMA_RECOVERY=true
XIAOZHUA_PIPELINE_LOAD_DEFAULT_COPY_BUNDLE=true
XIAOZHUA_PIPELINE_LOAD_DEFAULT_SYNONYM_MAP=true
XIAOZHUA_PIPELINE_ENFORCE_FORCED_MENTIONS=false
