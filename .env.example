# =============================================================================
# 小爪健康分诊 Agent — 运行时配置（非业务规则）
# 复制为 .env 后按需修改；业务规则（风险阈值、模板文案等）在 assets/ 中维护。
# =============================================================================

# --- HTTP API（前缀 HEALTH_API_）---
HEALTH_API_HOST=0.0.0.0
HEALTH_API_PORT=8080
# 启动时在 lifespan 中预加载 KB-TPL 等文案知识包；影响 /internal/readyz 是否就绪
HEALTH_API_PRELOAD_COPY_BUNDLE=true
HEALTH_API_ACCESS_LOG=true
# HEALTH_API_API_TITLE=小爪 AI 健康/兽医分诊 Agent V1
# HEALTH_API_API_VERSION=0.1.0
# 运维探针路径前缀；/healthz、/readyz 挂在此前缀下（与产品 POST /health 区分）
HEALTH_API_INTERNAL_PREFIX=/internal
# 是否挂载 POST /intelligent 静态占位端点（V1 不执行分诊管道，仅返回 mock 对话）
HEALTH_API_INTELLIGENT_ENABLED=true

# --- LLM：通义千问（前缀 QWEN_；仅当 XIAOZHUA_PIPELINE_LLM_ENABLED=true 时实际调用）---
# DashScope API Key；启用 LLM 文案路径时必填
# QWEN_API_KEY=
# OpenAI 兼容模式基址（见 docs/api/tongyi/request.md）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ③-2 DraftCopyJSON 生成所用模型；换 Qwen3 思考类模型需额外配置 enable_thinking
QWEN_MODEL=qwen-plus
QWEN_TIMEOUT_SEC=30
QWEN_MAX_RETRIES=2
# 文案生成采样温度；越低越稳定，越高越发散
QWEN_DEFAULT_TEMPERATURE=0.4
# 单次 chat.completions 最大生成 token 数（DraftCopyJSON 体量上限）
QWEN_DEFAULT_MAX_TOKENS=1200

# --- 制品路径（前缀 XIAOZHUA_；相对路径基于项目根）---
# 项目根绝对路径；Docker 内通常为 /app，本地省略则由包位置自动推断
# XIAOZHUA_PROJECT_ROOT=
# 20 case 验收数据集（批跑评测、开发回归）
XIAOZHUA_CASES_PATH=docs/cases/health_triage_cases.v1.json
# KB-TPL 文案模板目录（③-1 选模板、⑤ 机械兜底填槽）；兼容旧名 KB_TPL_DIR
KB_TPL_DIR=assets/kb-tpl/config
# KB-FORBID 禁止词表（④-B 内容守卫：确诊/保证性表述等）
XIAOZHUA_KB_FORBID_PATH=assets/kb-forbid/forbidden_patterns.v1.json
# KB-SYN 同义词表（语义评测 mustMention 扩展、守卫 forced mention 匹配）
XIAOZHUA_KB_SYN_PATH=assets/kb-syn/kb-syn.v1.json
# KB-ACTION 主行动按钮配置（⑤ primaryAction 映射）
XIAOZHUA_KB_ACTION_PATH=assets/kb-action/actions.v1.json
# triage-core 决策表 JSON 路径（预留接线；当前 ② 规则仍内嵌于 Python triage/）
# 兼容旧名 TRIAGE_CORE_PATH
TRIAGE_CORE_PATH=assets/triage-core/triage-core.v1.json
# action 矩阵评测 fixture（KB-ACTION 与 case 预期一致性校验）
XIAOZHUA_ACTION_MATRIX_PATH=assets/eval/action_matrix.v1.json

# --- 管道调试与行为开关（前缀 XIAOZHUA_PIPELINE_）---
# 跳过 ④-B ValidateContent（禁止词、证据真实性、紧急语气等）；仅本地调试
XIAOZHUA_PIPELINE_SKIP_CONTENT_GUARD=false
# 跳过出站 output_schema 全量校验；仅本地调试，生产务必保持 false
XIAOZHUA_PIPELINE_SKIP_FINAL_SCHEMA_CHECK=false
# 跳过 ⑤ merge-ready 预检；仅本地调试
XIAOZHUA_PIPELINE_SKIP_MERGE_READY_CHECK=false
# 内容守卫失败处理：strict=阻断并重试/兜底 | report_only=仅记录 | sanitize=尝试确定性修补后继续
XIAOZHUA_PIPELINE_GUARD_MODE=strict
# 是否走 LLM 文案路径（③-2 + ④ 重试）；false 时默认机械模板填槽（演示/里程碑 B 主路径）
XIAOZHUA_PIPELINE_LLM_ENABLED=false
# Merge 阶段失败后是否用纯模板机械填槽兜底（保证出站 JSON 合法）
XIAOZHUA_PIPELINE_ENABLE_MERGE_FALLBACK=true
# FinalSchema 校验失败后是否再执行一次机械 recovery 合并
XIAOZHUA_PIPELINE_ENABLE_FINAL_SCHEMA_RECOVERY=true
# copy_bundle 未显式传入时，运行期是否自动加载默认 KB-TPL / KB-FORBID / KB-ACTION
XIAOZHUA_PIPELINE_LOAD_DEFAULT_COPY_BUNDLE=true
# ValidateContent 是否加载默认 KB-SYN（forced mention / 同义词匹配）
XIAOZHUA_PIPELINE_LOAD_DEFAULT_SYNONYM_MAP=true
# mustMention 类 FORCED_MENTION_MISSING 是否作为 MED 违规阻断 guard（软门槛评测用）
XIAOZHUA_PIPELINE_ENFORCE_FORCED_MENTIONS=false
