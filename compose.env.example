# Docker Compose 专用变量（可选）
#
# 用法一：将下列变量合并进项目根 .env（推荐，Compose 会自动读取 .env 做插值）
# 用法二：cp compose.env.example compose.env && docker compose --env-file compose.env up
#
# 应用运行时配置（HEALTH_API_*、QWEN_*、XIAOZHUA_*）仍以 .env.example 为准。

# 镜像 tag（docker compose build / pull 使用）
IMAGE_TAG=local

# 宿主机映射端口 → 容器 8080
HEALTH_API_PUBLISH_PORT=8080

# 默认关闭 LLM；开启文案润色时在 .env 中设置 QWEN_API_KEY 并改为 true
XIAOZHUA_PIPELINE_LLM_ENABLED=false

# eval profile：批跑模式（risk-only | full-output | milestone-b | copy-llm）
EVAL_MODE=milestone-b
