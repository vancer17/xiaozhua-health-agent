      // 4.3 SafetyByFlag ───────────────────────────────────────────────────
      "safetyByFlag": {
        "description": "按 primaryFlag 决定 safetyNoticeRequired（bool）。为 true 时 ③ 必须填充 safetyNotice（可来自 kb-tpl/safety-notices 片段）；④ SafetyNoticeEnforcer 校验非空。与 case-rule-mapping §五 SN 列一致：仅 HRV_STRESS、SLOW_RECOVERY、DATA_MISSING、DATA_STALE 为 false。",
        "default": {
          "description": "未显式列出的 primaryFlag 默认值（不应触发；20 flag 均已枚举）",
          "safetyNoticeRequired": true
        },
        "entries": {
          "NORMAL_DAILY": {
            "description": "case #1；expected.safetyNoticeRequired=false",
            "safetyNoticeRequired": false
          },
          "POST_EXERCISE": {
            "description": "case #2/#5；watch 但仍需非诊断边界说明",
            "safetyNoticeRequired": true
          },
          "FEVER_RESTING": {
            "description": "warning",
            "safetyNoticeRequired": true
          },
          "RESP_RESTING": {
            "description": "warning",
            "safetyNoticeRequired": true
          },
