            "safetyNoticeRequired": true
          }
        }
      },
  
      // 4.4 ActionByFlagRisk ────────────────────────────────────────────────
      "actionByFlagRisk": {
        "description": "按 primaryFlag 提供 primaryActionHint 枚举；⑤ MergeOutput 经 KB-ACTION 映射为 output_schema.primaryAction { label, route }。多数 warning CTX 为 contact_vet；emergency 为 emergency_now；数据问题为 check_device；可观察 watch 为 rest_observe。可选 riskLevelOverrides 用于同 flag 不同 risk 的细调（V1 20 case 通常不需要）。",
        "hintEnumDocs": {
          "description": "primaryActionHint 允许值说明；KB-ACTION 表负责 hint → label/route",
          "emergency_now": "立即联系兽医/就近就医（emergency）",
          "contact_vet": "建议联系兽医评估（warning 为主）",
          "check_device": "检查设备佩戴、电量与数据同步（DATA_*）",
          "rest_observe": "休息观察、补水、后续复查（normal / 运动后 watch）"
        },
        "entries": {
          "NORMAL_DAILY": {
            "description": "日常正常",
            "defaultHint": "rest_observe"
          },
          "POST_EXERCISE": {
