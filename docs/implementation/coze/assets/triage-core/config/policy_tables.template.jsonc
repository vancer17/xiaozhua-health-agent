            "description": "疫苗后疲倦 watch",
            "themes": ["确诊"]
          },
          "DATA_MISSING": {
            "description": "数据缺失；严禁在缺数据时声称健康",
            "themes": ["确诊", "正常", "一定没事", "目前健康", "一切正常"]
          },
          "DATA_STALE": {
            "description": "数据过期；严禁依据旧数据断言当前状态",
            "themes": ["确诊", "当前正常", "一切正常", "现在很正常", "目前正常"]
          },
          "EMERGENCY_SEIZURE": {
            "description": "抽搐 emergency",
            "themes": ["确诊", "继续观察即可", "不用看医生", "先观察", "不着急"]
          },
