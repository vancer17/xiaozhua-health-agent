    // ── PolicyTablesResolve 运行时契约（供 policy_tables.py 实现对照）────────
    "resolveContract": {
      "description": "声明 PolicyTablesResolve 的输入、输出与合并顺序；Python 引擎须与此一致，Coze 代码节点同理",
      "inputs": {
        "description": "Resolve 所需输入字段",
        "primaryFlag": "ResolvePrimaryFlag 选定的唯一主键",
        "finalRiskLevel": "fusion 产出：normal | watch | warning | emergency",
        "mentionsAddFromRules": "各命中 rules[].then.mentionsAdd 的去重并集（可为空数组）"
      },
      "outputs": {
        "description": "写入 TriageCoreResult 的字段",
        "forcedMentions": "forcedMentionsByFlag[primaryFlag].mentions ∪ mentionsAddFromRules（去重保序）",
        "forbiddenThemes": "forbiddenByFlag[primaryFlag].themes ∪ globalForbiddenPatterns（主题级并集）",
        "safetyNoticeRequired": "safetyByFlag.entries[primaryFlag].safetyNoticeRequired",
        "primaryActionHint": "actionByFlagRisk.entries[primaryFlag].defaultHint（或 riskLevelOverrides 命中值）"
      },
      "executionOrder": {
        "description": "在 ② 管道中的位置；详见 triage-core-spec.md §七",
        "after": ["ConfidenceResolver"],
        "before": ["missingDataUser", "EvidenceBuilder", "TriageCoreResultAssembly"]
      },
      "validationChecks": {
        "description": "Loader 启动时建议执行的静态校验",
        "requireAllPrimaryFlags": "forcedMentionsByFlag / forbiddenByFlag / safetyByFlag / actionByFlagRisk 四表 key 集合必须完全一致（20 个）",
        "requireKnownHints": "所有 defaultHint 必须在 hintEnumDocs 定义的枚举内",
        "crossRefRules": "entries.*.ruleIds 中的 id 须在 rules 代码或 triage-core rules[] 中存在"
      }
    }
  }